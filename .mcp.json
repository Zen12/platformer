{
  "mcpServers": {
    "platformer-assets": {
      "type": "stdio",
      "command": "${PROJECT_ROOT}/venv/bin/python",
      "args": [
        "${PROJECT_ROOT}/mcp_tools/server/asset_server.py"
      ],
      "env": {}
    },
    "blender": {
      "type": "stdio",
      "command": "${PROJECT_ROOT}/venv/bin/python",
      "args": [
        "${PROJECT_ROOT}/mcp_tools/server/blender_server.py"
      ],
      "env": {
        "BLENDER_PATH": "/opt/homebrew/bin/blender"
      }
    },
    "gimp": {
      "type": "stdio",
      "command": "${PROJECT_ROOT}/venv/bin/python",
      "args": [
        "${PROJECT_ROOT}/mcp_tools/server/gimp_server.py"
      ],
      "env": {
        "GIMP_PATH": "/opt/homebrew/bin/gimp"
      }
    },
    "figma": {
      "type": "stdio",
      "command": "${PROJECT_ROOT}/venv/bin/python",
      "args": [
        "${PROJECT_ROOT}/mcp_tools/server/figma_server.py"
      ],
      "env": {
        "FIGMA_TOKEN": "<your-token-here>"
      }
    }
  }
}