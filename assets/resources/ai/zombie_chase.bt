name: zombie_chase
root:
  type: sequence
  children:
    # Always find target first
    - type: find_target_by_tag
      tag: male
      radius: 50.0
    # Then decide: attack or chase
    - type: selector
      children:
        - type: sequence
          children:
            - type: has_target_in_range
              range: 0.4
            - type: attack
              duration: 1.0
        - type: move_to_target
