name: enviremont_scene
type: scene
entities:
  # Camera positioned to view models one by one
  - guid: env-camera
    tag: main_camera
    components:
      - type: transform
        position: [0.0, 3.0, 8.0]
        rotation: [-15.0, 0.0, 0.0]
        scale: [1.0, 1.0, 1.0]
      - type: camera
        perspectiveNearPlane: 0.1
        perspectiveFarPlane: 200.0
        perspectiveAspect: 60
        orthographicAspect: 70
        isPerspective: true
      - type: camera_controller
        move_speed: 10.0
        mouse_sensitivity: 0.1

  # Bridge
  - tag: "bridge"
    components:
      - type: transform
        position: [0.0, 0.0, 0.0]
        rotation: [0.0, 0.0, 0.0]
        scale: [1.0, 1.0, 1.0]
      - type: mesh_renderer
        material: 40ea94a0-ec3c-4e84-99c1-55a1d935e847
        mesh: 15ad553c-e36c-4873-87c2-d4f719026afc
