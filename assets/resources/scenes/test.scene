name: test_scene
type: scene
entities:
  - tag: "zombie"
    components:
      - type: transform
        position: [5.0, 0.0, -40.0]
        rotation: [0.0, 0.0, 0.0]
        scale: [0.1, 0.1, 0.1]
      - type: skinned_mesh_renderer
        material: 1f675ea6-d9c2-442a-a22a-c601695d537d
        mesh: 54664be6-1926-4333-8e75-1a3dd4d001a3
      - type: simple_animation
        animation: 9df5a4bb-b644-4274-9c11-1799cfd3d98b
        apply_root_motion: false
  - tag: "male"
    components:
      - type: transform
        position: [0.0, 0.0, -40.0]
        rotation: [0.0, 0.0, 0.0]
        scale: [9.0, 9.0, 9.0]
      - type: skinned_mesh_renderer
        material: edb1cb63-5e34-47b8-9abe-9bace664825a
        mesh: 9cfdfa5d-180d-4a9b-a780-e5042e17367c
      - type: simple_animation
        animation: b624e619-5108-4ae7-9ff3-9392feee577e
        apply_root_motion: false
  - guid: main-camera
    tag: main_camera
    components:
      - type: transform
        position: [0, 0.0, 0.0]
        rotation: [0.0, 0.0, 0.0]
        scale: [1.0, 1.0, 1.0]
      - type: camera
        perspectiveNearPlane: 0.1
        perspectiveFarPlane: 100.0
        perspectiveAspect: 60
        orthographicAspect: 70
        isPerspective: true
      - type: camera_controller
        move_speed: 10.0
        mouse_sensitivity: 0.1
