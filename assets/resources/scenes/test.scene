entities:
  - tag: "zombie_spawner"
    components:
      - type: spawner
        prefab_guid: ee9e7ec4-779d-4d44-a4f6-99f048412b61  # zombie.prefab
        spawn_count: 10
        spawn_on_navmesh: true
  - tag: "male"
    components:
      - type: transform
        position: [3.0, 1.0, 3.0]
        rotation: [0.0, 0.0, 0.0]
        scale: [1.0, 1.0, 1.0]
      - type: skinned_mesh_renderer
        material: edb1cb63-5e34-47b8-9abe-9bace664825a
        mesh: 9cfdfa5d-180d-4a9b-a780-e5042e17367c
      - type: fsm_animation
        fsm_guid: 0dd46701-6ea4-47fc-9644-b6ffa0ce0da3
        loop: true
        animation_speed: 2.0
        velocity_based_speed: true
        velocity_speed_scale: 1.0
        use_directional_blending: true
      - type: ik_aim
        enabled: true
        blend_weight: 1.0
        blend_speed: 5.0
        torso_max_yaw: 60.0
        torso_max_pitch: 30.0
        spine_weight: 0.3
        spine1_weight: 0.4
        chest_weight: 0.3
        left_hand_grip_point: [0.3, 0.0, 0.2]
        right_elbow_hint: [0.0, 0.0, -1.0]
        left_elbow_hint: [0.0, 0.0, -1.0]
      - type: navmesh_agent
        gravity: -20.0
        jump_force: 10.0
        air_control_multiplier: 0.8
        radius: 0.1
        rotation_speed: 15.0
        max_speed: 1.0
        enabled: true
        ignore_crowd_velocity: true
      - type: player_controller
        move_speed: 2.0
        destination_distance: 1.0
      - type: health
        max_health: 100.0
      - type: audio_listener
      - type: particle_emitter
        material_guid: 26232f01-48b5-4b43-8bd2-d6fc30c7c127
        mesh_guid: sprite
        max_particles: 15
        emission_rate: 0.0
        particle_lifetime: 0.8
        lifetime_variance: 0.1
        initial_velocity: [0.0, 1.0, 0.0]
        velocity_variance: [2.5, 0.5, 2.5]
        gravity: [0.0, 6.0, 0.0]
        start_color: [0.6, 0.6, 0.6, 0.8]
        end_color: [0.4, 0.4, 0.4, 0.0]
        particle_size: 0.8
        trigger_on_land: true
        trigger_on_damage: false
        burst_count: 8
  - guid: main-camera
    tag: main_camera
    components:
      - type: transform
        position: [0, 15.0, 20.0]
        rotation: [-90.0, 0.0, 0.0]
        scale: [1.0, 1.0, 1.0]
      - type: camera
        perspectiveNearPlane: 0.1
        perspectiveFarPlane: 100.0
        perspectiveAspect: 60
        orthographicAspect: 70
        isPerspective: true
      - type: top_down_camera
        target_tag: male
        offset_position: [0.0, 10.0, 10.0]
        offset_rotation: [-50.0, 0.0, 0.0]
        max_look_ahead: 7.0
        smooth: 1.4
        max_move_speed: 10.0
  - tag: "sun"
    components:
      - type: transform
        position: [0.0, 0.0, 0.0]
        rotation: [-45.0, 45.0, 0.0]
        scale: [1.0, 1.0, 1.0]
      - type: directional_light
        aspect_ratio: 1.0
        near_plane: 0.1
        far_plane: 100.0
        ortho_size: 44.0
        follow_tag: "male"
        follow_offset: [0.0, 20.0, 0.0]
