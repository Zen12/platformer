name: test_scene
type: scene
navmesh:
  width: 100
  height: 1
  depth: 100
  cell_size: 1.0
  origin: [-50.0, 0.0, -50.0]
entities:
  - tag: "zombie"
    components:
      - type: transform
        position: [5.0, 0.0, -40.0]
        rotation: [0.0, 0.0, 0.0]
        scale: [0.1, 0.1, 0.1]
      - type: skinned_mesh_renderer
        material: 1f675ea6-d9c2-442a-a22a-c601695d537d
        mesh: 54664be6-1926-4333-8e75-1a3dd4d001a3
      - type: fsm_animation
        fsm_guid: b9fcf65a-3a68-4990-aa56-e4a5945b0093
        loop: true
      - type: navmesh_agent
        radius: 0.5
        max_speed: 3.0
        enabled: true
  - tag: "male"
    components:
      - type: transform
        position: [0.0, 0.0, -40.0]
        rotation: [0.0, 0.0, 0.0]
        scale: [9.0, 9.0, 9.0]
      - type: skinned_mesh_renderer
        material: edb1cb63-5e34-47b8-9abe-9bace664825a
        mesh: 9cfdfa5d-180d-4a9b-a780-e5042e17367c
      - type: fsm_animation
        fsm_guid: 0dd46701-6ea4-47fc-9644-b6ffa0ce0da3
        loop: true
      - type: navmesh_agent
        radius: 0.8
        max_speed: 5.0
        enabled: true
  - guid: main-camera
    tag: main_camera
    components:
      - type: transform
        position: [0, 20.0, 30.0]
        rotation: [-30.0, 0.0, 0.0]
        scale: [1.0, 1.0, 1.0]
      - type: camera
        perspectiveNearPlane: 0.1
        perspectiveFarPlane: 100.0
        perspectiveAspect: 60
        orthographicAspect: 70
        isPerspective: true
      - type: camera_controller
        move_speed: 10.0
        mouse_sensitivity: 0.1
