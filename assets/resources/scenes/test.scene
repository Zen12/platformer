entities:
  - tag: "zombie_spawner"
    components:
      - type: spawner
        prefab_guid: ee9e7ec4-779d-4d44-a4f6-99f048412b61  # zombie.prefab
        spawn_count: 2
        spawn_on_navmesh: true
  - tag: "navmesh_cell_spawner"
    components:
      - type: spawner
        prefab_guid: dbef9cd0-1b7d-4e83-99aa-7a5fdb80bd75  # navmesh_marker.prefab
        spawn_on_all_cells: true
        y_offset: -0.1
  - tag: "male"
    components:
      - type: transform
        position: [3.0, 0.0, 3.0]
        rotation: [0.0, 0.0, 0.0]
        scale: [1.0, 1.0, 1.0]
      - type: skinned_mesh_renderer
        material: edb1cb63-5e34-47b8-9abe-9bace664825a
        mesh: 9cfdfa5d-180d-4a9b-a780-e5042e17367c
      - type: fsm_animation
        fsm_guid: 0dd46701-6ea4-47fc-9644-b6ffa0ce0da3
        loop: true
        animation_speed: 2.0
        velocity_based_speed: true
        velocity_speed_scale: 1.0
      - type: navmesh_agent
        gravity: -20.0
        jump_force: 10.0
        air_control_multiplier: 0.8
        radius: 0.1
        rotation_speed: 15.0
        max_speed: 5.0
        enabled: true
        ignore_crowd_velocity: true
      - type: player_controller
        move_speed: 5.0
        destination_distance: 1.0
  - guid: main-camera
    tag: main_camera
    components:
      - type: transform
        position: [0, 15.0, 20.0]
        rotation: [-90.0, 0.0, 0.0]
        scale: [1.0, 1.0, 1.0]
      - type: camera
        perspectiveNearPlane: 0.1
        perspectiveFarPlane: 100.0
        perspectiveAspect: 60
        orthographicAspect: 70
        isPerspective: true
      - type: top_down_camera
        target_tag: male
        offset_position: [0.0, 10.0, 10.0]
        offset_rotation: [-50.0, 0.0, 0.0]
        max_look_ahead: 7.0
        smooth: 1.4
        max_move_speed: 10.0
  - tag: "bridge"
    components:
      - type: transform
        position: [18.0, 0.0, 10.5]
        rotation: [0.0, 0.0, 0.0]
        scale: [0.7, 0.7, 0.7]
      - type: mesh_renderer
        material: 40ea94a0-ec3c-4e84-99c1-55a1d935e847
        mesh: 15ad553c-e36c-4873-87c2-d4f719026afc
  - tag: "sun"
    components:
      - type: transform
        position: [0.0, 0.0, 0.0]
        rotation: [-45.0, -45.0, 0.0]
        scale: [1.0, 1.0, 1.0]
      - type: directional_light
        aspect_ratio: 1.0
        near_plane: 0.1
        far_plane: 100.0
        ortho_size: 44.0
        follow_tag: "male"
        follow_offset: [0.0, 20.0, 0.0]