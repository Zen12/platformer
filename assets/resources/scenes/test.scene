name: test_scene
type: scene
entities:
  - components:
      - type: transform
        position: [0.0, 0.0, -5.0]
        rotation: [0.0, 0.0, 0.0]
        scale: [1.0, 1.0, 1.0]
      - type: mesh_renderer
        material: 566ef6f8-bc3f-4ca9-bdfb-d2c2f9ee5b47
        mesh: a1b2c3d4-5e6f-7a8b-9c0d-1e2f3a4b5c6d
  - guid: main-camera
    tag: main_camera
